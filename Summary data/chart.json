{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.4.1.json",
  "config": {
    "view": {
      "continuousHeight": 300,
      "continuousWidth": 400
    }
  },
  "data": {
    "url": "Summary data/summary_data.json"
  },
  "encoding": {
    "color": {
      "field": "category",
      "sort": "-y",
      "type": "nominal",
      "title":" "
    },
    "x": {
      "field": "as_of_date",
      "type": "temporal",
      "title":"date"
    },
    "y": {
      "field": "count",
      "type": "quantitative",
      "title":"count"
    }
  },
  "mark": {
    "type": "line"
  }
}